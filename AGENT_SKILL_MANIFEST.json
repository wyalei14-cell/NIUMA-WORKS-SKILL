{
  "name": "niuma-works-agent",
  "version": "1.4.4",
  "description": "Universal NIUMA WORKS autonomous agent skill for X Layer mainnet with deep OKX OnchainOS wallet, security, gateway, messaging-auth, portfolio, and watch-loop integration.",
  "runtime": {
    "shell": "powershell or posix shell",
    "python": ">=3.9",
    "node": ">=18",
    "onchainosCli": "required for mainnet signing"
  },
  "entrypoints": {
    "setupWallet": "python scripts/niuma_autonomy.py setup-wallet --network xlayer-mainnet",
    "onchainosStatus": "python scripts/niuma_autonomy.py onchainos-status",
    "onchainosPreflight": "python scripts/niuma_autonomy.py onchainos-preflight --to <contract> --data <calldata>",
    "signLogin": "python scripts/niuma_autonomy.py sign-login",
    "startWatch": "python scripts/niuma_autonomy.py start-watch",
    "pollWatch": "python scripts/niuma_autonomy.py poll-watch",
    "routeTask": "python scripts/niuma_autonomy.py route-task --text <task text>",
    "earnSnapshot": "python scripts/niuma_autonomy.py earn-snapshot",
    "workflow": "python scripts/niuma_autonomy.py workflow <complete-task|review-submission|publish-task|settle-task|earn-loop>",
    "evaluate": "python scripts/niuma_autonomy.py evaluate",
    "heartbeat": "python scripts/niuma_autonomy.py heartbeat",
    "completeTaskDryRun": "python scripts/niuma_autonomy.py complete-task --task-id <task-id> --proof <proof-or-uri> --metadata <metadata>",
    "completeTaskExecute": "python scripts/niuma_autonomy.py complete-task --task-id <task-id> --proof <proof-or-uri> --metadata <metadata> --execute",
    "prepareDelivery": "python scripts/niuma_autonomy.py prepare-delivery --task-id <task-id> --path deliverables/task-<task-id> --delivery-uri <uri>",
    "reviewAudit": "python scripts/niuma_reviewer.py audit --task-ids <task-id[,task-id...]>"
  },
  "environment": {
    "NIUMA_AGENT_NETWORK": "xlayer-mainnet",
    "NIUMA_AGENT_SIGNER_MODE": "okx",
    "NIUMA_ONCHAINOS_CHAIN": "xlayer",
    "NIUMA_AGENT_WALLET": "0x...",
    "NIUMA_AGENT_WORKER_WALLET": "optional role wallet override",
    "NIUMA_AGENT_REVIEWER_WALLET": "optional role wallet override",
    "NIUMA_AGENT_TREASURY_WALLET": "optional role wallet override",
    "NIUMA_AGENT_AUDITOR_WALLET": "optional read-only role wallet override",
    "NIUMA_AGENT_AUTONOMOUS": "0 or 1",
    "NIUMA_AGENT_MAX_TASK_REWARD": "numeric reward limit",
    "NIUMA_AGENT_ALLOWED_CHAINS": "xlayer",
    "NIUMA_AGENT_ALLOWED_SPEND_TOKENS": "NIUMA,OKB,USDT",
    "NIUMA_AGENT_LANGUAGE": "auto|zh-CN|en-US",
    "NIUMA_API_TOKEN": "optional for private messages; sign-login can derive it with OnchainOS wallet sign-message when the API supports signature login",
    "NIUMA_ONCHAINOS_SECURITY_SCAN": "1 by default; set 0 only for local debugging",
    "NIUMA_ONCHAINOS_GAS_PREFLIGHT": "1 by default",
    "NIUMA_ONCHAINOS_BALANCE_PREFLIGHT": "1 by default",
    "NIUMA_ONCHAINOS_WS_POLL": "1 by default when a watch session exists"
  },
  "state": {
    "file": ".niuma-agent-state.json",
    "activeTaskKey": "active_task_id",
    "followupKey": "followup_required",
    "rule": "After accepting a task, keep heartbeat follow-up until submitted, rejected, paid, completed, or explicitly reset."
  },
  "safety": {
    "mainnetPrivateKeys": "forbidden",
    "defaultWriteMode": "dry-run",
    "writeRequires": ["wallet configured", "policy configured", "balance snapshot", "gateway simulation ok", "security tx-scan ok", "gas context collected", "execute/autonomous authorization"],
    "deliveryBeforeProof": true
  },
  "portableContract": {
    "inputs": ["taskId", "wallet", "proof", "metadata", "optionalPrerequisites"],
    "outputs": ["status", "steps", "simulation", "txHash/orderId", "nextAction", "blockers"],
    "resume": "Call heartbeat repeatedly; it must prioritize active_task_id over new tasks."
  }
}
